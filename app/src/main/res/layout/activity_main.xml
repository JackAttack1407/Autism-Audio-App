<?xml version="1.0" encoding="utf-8"?>
<!-- layout validation "errors" are just reccomendations for ux -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_soft"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top buttons (CARD) -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnToggle"
            style="@style/BubbleButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="@string/start" />

        <Button
            android:id="@+id/btnConfig"
            style="@style/BubbleButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_button" />

        <Button
            android:id="@+id/test_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Button" />
    </LinearLayout>

    <!-- Meter (CARD) -->
    <TextView
        android:id="@+id/meterText"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_card"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/audio_start"
        android:textSize="18sp" />

    <!-- Audio level (CARD) -->
    <com.example.autismaudioapp.AudioLevelView
        android:id="@+id/levelView"
        android:layout_width="match_parent"
        android:layout_height="115dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_card"
        android:padding="12dp" />

    <!-- File buttons (CARD) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnChoose"
            style="@style/BubbleButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/choose_file" />

        <Button
            android:id="@+id/btnRemove"
            style="@style/BubbleButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remove_file" />
    </LinearLayout>

    <!-- Playlist (CARD) -->
    <ListView
        android:id="@+id/playlistView"
        android:layout_width="match_parent"
        android:layout_height="276dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_card"
        android:dividerHeight="1dp"
        android:padding="8dp" />

    <!-- Playback (CARD) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnPrev"
            style="@style/BubbleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/prev" />

        <Button
            android:id="@+id/btnPlay"
            style="@style/BubbleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/play" />


        <Button
            android:id="@+id/btnNext"
            style="@style/BubbleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/next" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/current_time" />

        <SeekBar
            android:id="@+id/songSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/total_time" />

    </LinearLayout>

    <!-- Seek (CARD) -->

</LinearLayout>